@using restaurant.Controllers
@model List<CatalogItem>

@{
    ViewData["Title"] = "Menu Catalog";
    var currentSort = ViewBag.Sort as string ?? "asc";
    var nextSort = currentSort == "asc" ? "desc" : "asc";
    var sortLabel = currentSort == "asc" ? "Price ↑" : "Price ↓";
}

<div class="container mt-4">
    <h3>Menu Catalog</h3>
    <p class="text-muted">Browse confirmed menu items from all restaurants.</p>

    <!-- Search and sort bar -->
    <div class="row g-2 mb-4">
        <div class="col-md-8">
            <input type="text" id="searchInput" class="form-control"
                   placeholder="Search for a dish e.g. Burger, Pasta..."
                   value="@ViewBag.Search" />
        </div>
        <div class="col-md-2">
            <a asp-controller="Menu" asp-action="Index"
               asp-route-search="@ViewBag.Search"
               asp-route-sort="@nextSort"
               class="btn btn-outline-secondary w-100">
                Sort by @sortLabel
            </a>
        </div>
        <div class="col-md-2">
            <button id="searchBtn" class="btn btn-primary w-100">Search</button>
        </div>
    </div>

    <!-- Results -->
    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            No confirmed menu items found yet. Upload a menu and wait for processing.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Restaurant</th>
                        <th>Dish</th>
                        <th>Price (€)</th>
                        <th>Translate</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.RestaurantName</td>
                            <td>@item.ItemName</td>
                            <td>€ @item.Price.ToString("F2")</td>
                            <td>
                                <div class="d-flex gap-2 align-items-center">
                                    <select class="form-select form-select-sm lang-select"
                                            style="width:120px;">
                                        <option value="mt">Maltese</option>
                                        <option value="fr">French</option>
                                        <option value="de">German</option>
                                        <option value="it">Italian</option>
                                        <option value="es">Spanish</option>
                                        <option value="ar">Arabic</option>
                                    </select>
                                    <button class="btn btn-sm btn-outline-primary translate-btn"
                                            data-menu-id="@item.MenuId"
                                            data-restaurant-id="@item.RestaurantId"
                                            data-text="@item.ItemName">
                                        Translate
                                    </button>
                                    <span class="translation-result text-success fst-italic"></span>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/catalog.js"></script>
    <script>
        // Client-side search filter
        document.getElementById('searchBtn').addEventListener('click', function () {
            const search = document.getElementById('searchInput').value;
            const sort = '@currentSort';
            window.location.href = `/Menu/Index?search=${encodeURIComponent(search)}&sort=${sort}`;
        });

        document.getElementById('searchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') document.getElementById('searchBtn').click();
        });
    </script>
}
